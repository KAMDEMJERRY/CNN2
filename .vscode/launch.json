{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/votre_executable", // À modifier
            "args": [],
            "cwd": "${workspaceFolder}",
            "setupCommands": [
                {
                    "description": "Enable pretty printing",
                    "text": "settings set target.enable-synthetic-value true"
                }
            ],
            "initCommands": [
                "settings set target.enable-synthetic-value true"
            ],
            "sourceMap": {
                "/build/": "${workspaceFolder}"
            },
            "stopAtEntry": false,
            "console": "integratedTerminal", // Ou "externalTerminal"
            "internalConsoleOptions": "openOnSessionStart"
        }
    ]
}

